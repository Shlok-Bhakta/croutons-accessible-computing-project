{
  "name": "croutons-universal-sensory-filter",
  "displayName": "Universal Sensory Filter",
  "version": "0.0.1",
  "description": "Croutons — calmer, clearer browsing for neurodivergent users.",
  "author": "Croutons",
  "scripts": {
    "dev": "plasmo dev",
    "build": "plasmo build",
    "package": "plasmo package"
  },
  "dependencies": {
    "@mozilla/readability": "^0.6.0",
    "plasmo": "0.90.5",
    "react": "18.3.1",
    "react-dom": "18.3.1"
  },
  "devDependencies": {
    "@ianvs/prettier-plugin-sort-imports": "4.1.1",
    "@types/chrome": "0.0.268",
    "@types/node": "20.11.5",
    "@types/react": "18.3.12",
    "@types/react-dom": "18.3.1",
    "prettier": "3.2.4",
    "typescript": "5.3.3"
  },
  "manifest": {
    "host_permissions": [
      "http://*/*",
      "https://*/*"
    ],
    "permissions": [
      "storage",
      "scripting",
      "tabs"
    ]
  }
}
